<Project>
	<Target Name="ILRepacker" AfterTargets="Build">
		<ItemGroup>
			<InputAssemblies Include="$(OutputPath)\Lidarr.Plugin.AppleMusic.dll" />
		</ItemGroup>

		<ItemGroup>
			<LibraryPath Include="$(OutputPath)" />
			<LibraryPath Include="..\..\ext\Lidarr\src\NzbDrone.Core\bin\$(Configuration)\net8.0" />
		</ItemGroup>

		<ILRepack
			Parallel="true"
			Internalize="true"
			InputAssemblies="@(InputAssemblies)"
			LibraryPath="@(LibraryPath)"
			TargetKind="Dll"
			OutputFile="$(OutputPath)\$(AssemblyName).dll" />
	</Target>
</Project>
